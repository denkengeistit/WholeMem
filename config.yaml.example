# WholeMem MCP Configuration
# Copy to config.yaml and adjust to your setup.
# Environment variables override these values (prefix: WHOLEMEM_).

screenpipe:
  url: "http://localhost:3030"
  managed: true                         # start/stop Screenpipe with the MCP server
  command: "npx screenpipe@latest"       # command to launch Screenpipe
  disable_telemetry: true               # pass --disable-telemetry to Screenpipe

llm:
  # OpenAI-compatible endpoint (LM Studio, vLLM, Ollama /v1, etc.)
  base_url: "http://localhost:1234/v1"
  model: "qwen3-1.7b"
  api_key: "lm-studio"          # most local servers accept any string

embedder:
  # "openai" (any OpenAI-compatible endpoint, e.g. LM Studio) or "ollama"
  provider: "openai"
  model: "nomic-embed-text"
  base_url: "http://localhost:1234/v1"  # same server as the LLM
  # embedding_dims: 768                 # uncomment if your model differs

mem0:
  user_id: "default_user"
  # qdrant_path: "~/.wholemem/qdrant"  # on-disk vector store

obsidian:
  vault_path: "~/Documents/Obsidian"
  daily_notes_subfolder: "Daily Notes"  # relative to vault_path

daemon:
  interval_minutes: 15

watcher:
  enabled: true
  path: "~/Scratch"                     # workspace root to watch
  exclude:
    - "node_modules/"
    - ".git/"
    - "__pycache__/"
    - "*.pyc"
    - "build/"
    - "dist/"
    - ".DS_Store"

versioning:
  compression_level: 3                  # zstd compression level
  db_path: "~/.wholemem/"               # per-workspace DBs written here
  history_depth: 3                      # max versions kept per file

oracle:
  history_depth: 50                     # max version entries in oracle context
  session_timeout_minutes: 30           # idle timeout before session auto-completes
